# ─────────────────────────────────────────────────────────────────────────────
# HireRanker — Render + Vercel + Neon + Upstash deployment env vars
# Copy these into the Render dashboard under Environment → Add Variable
# (or paste into your local .env for testing production settings locally)
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-generate-with-python-secrets   # python -c "import secrets; print(secrets.token_urlsafe(50))"
ALLOWED_HOSTS=hireranker-api.onrender.com            # add comma-separated custom domain if needed
DJANGO_LOG_LEVEL=WARNING

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Get these from: console.neon.tech → your project → Connection Details
DB_HOST=ep-xxxx.us-east-2.aws.neon.tech
DB_NAME=hireranker
DB_USER=hireranker_owner
DB_PASSWORD=your-neon-password
DB_PORT=5432

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Get these from: console.upstash.com → your database → Details → Redis URL
# All three should point to the same Upstash instance (different DB indexes are fine)
REDIS_URL=rediss://default:your-upstash-password@your-hostname.upstash.io:6379
CELERY_BROKER_URL=rediss://default:your-upstash-password@your-hostname.upstash.io:6379/1
CELERY_RESULT_BACKEND=rediss://default:your-upstash-password@your-hostname.upstash.io:6379/2

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini   # cheapest; switch to gpt-4o for better quality
OPENAI_FAST_MODEL=gpt-4o-mini

# ── File Storage ──────────────────────────────────────────────────────────────
# false = local storage (files lost on Render redeploy — OK for MVP/demo)
# true  = requires AWS_* vars below
USE_S3=false

# AWS S3 (only needed if USE_S3=true)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=hireranker-media
# AWS_S3_REGION_NAME=us-east-1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (set this AFTER first Vercel deploy)
CORS_ALLOWED_ORIGINS=https://hireranker.vercel.app

# ── Stripe (optional — leave blank to disable billing) ────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (optional — leave blank to disable transactional email) ─────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@hireranker.com

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (set these in Vercel dashboard → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://hireranker-api.onrender.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=        # same as STRIPE_PUBLISHABLE_KEY above
