# =============================================================================
# HireRanker Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
#
# Generate SECRET_KEY with:
#   openssl rand -base64 50
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-base64-50
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://hireranker:your_password@postgres:5432/hireranker
POSTGRES_DB=hireranker
POSTGRES_USER=hireranker
POSTGRES_PASSWORD=your_strong_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# LLM Provider (OpenAI / OpenAI-compatible)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EVALUATION_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# AWS S3 (for production file storage)
# Set USE_S3=True to store uploaded resumes and media in S3/R2 instead of disk
# -----------------------------------------------------------------------------
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=hireranker-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=  # Leave blank for AWS S3; set for Cloudflare R2 or other S3-compatible

# -----------------------------------------------------------------------------
# Stripe (Payments)
# Use test keys for development, live keys for production
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
CANDIDATE_REVIEW_PRICE_USD=999  # in cents — $9.99 per public review

# -----------------------------------------------------------------------------
# Error Tracking (Sentry)
# Leave blank to disable
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Email (SendGrid via SMTP)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Frontend (Next.js public vars — baked into the client bundle at build time)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# File Upload Limits
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
MAX_RESUME_SIZE_MB=10
MAX_BULK_RESUME_COUNT=50

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
REVIEW_ENDPOINT_RATE_LIMIT=10/hour
